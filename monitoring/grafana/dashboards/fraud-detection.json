{
  "uid": "fraud-detection-pipeline",
  "title": "Fraud Detection Pipeline - Latency & Metrics",
  "tags": [
    "fraud",
    "latency",
    "alerts",
    "model"
  ],
  "timezone": "browser",
  "refresh": "1s",
  "schemaVersion": 38,
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "type": "timeseries",
      "title": "Pipeline Latency (Detector to Report) - p50",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(fraud_pipeline_latency_seconds_bucket{stage=\"detector_to_report\"}[30s]))",
          "legendFormat": "p50 (median)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 2,
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "type": "timeseries",
      "title": "Fraud Alerts by Tier",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(fraud_alerts_total{tier=\"1\"}[1m])) * 60",
          "legendFormat": "Tier 1 (Critical)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(fraud_alerts_total{tier=\"2\"}[1m])) * 60",
          "legendFormat": "Tier 2 (Score-Based)",
          "refId": "B"
        },
        {
          "expr": "sum(rate(fraud_alerts_total{tier=\"3\"}[1m])) * 60",
          "legendFormat": "Tier 3 (ML-Based)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 3,
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 6,
        "h": 6
      },
      "type": "timeseries",
      "title": "Model Updates/Hour",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(fraud_model_updates_total[5m]) * 3600",
          "legendFormat": "Updates/Hour",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30
          }
        }
      }
    },
    {
      "id": 4,
      "gridPos": {
        "x": 6,
        "y": 8,
        "w": 6,
        "h": 6
      },
      "type": "gauge",
      "title": "F1 Score (5m avg)",
      "description": "5-minute simple moving average",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "avg_over_time(max(fraud_model_f1_score)[5m:30s]) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 50,
                "color": "yellow"
              },
              {
                "value": 75,
                "color": "green"
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 5,
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 6,
        "h": 6
      },
      "type": "stat",
      "title": "Detector Latency (p50)",
      "description": "p50 detector processing time in ms",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(fraud_latency_seconds_bucket{stage=\"detector_total\"}[1m])) * 1000",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 500,
                "color": "yellow"
              },
              {
                "value": 1000,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 6,
      "gridPos": {
        "x": 18,
        "y": 8,
        "w": 6,
        "h": 6
      },
      "type": "stat",
      "title": "Total Alerts (Last Hour)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(fraud_alerts_total[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "locale",
          "decimals": 0,
          "thresholds": {
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 100,
                "color": "yellow"
              },
              {
                "value": 500,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    }
  ]
}